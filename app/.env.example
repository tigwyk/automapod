# Environment Variables for AutomaPod App
# Copy this file to .env.local and fill in the values

# ============================================
# REQUIRED - Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# REQUIRED - E2E Test Credentials
# ============================================
# Test user credentials for E2E tests
# Create this user in your Supabase auth before running tests
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123!

# ============================================
# REQUIRED - Groq AI (Transcription)
# ============================================
GROQ_API_KEY=your-groq-api-key

# ============================================
# REQUIRED - Cloudflare R2 (Storage)
# ============================================
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_EPISODES_BUCKET=automapod-episodes
R2_IMAGES_BUCKET=automapod-images
# Public endpoints (after enabling public access in R2 bucket settings)
R2_EPISODES_PUBLIC_URL=https://your-account-id.r2.cloudflarestorage.com/automapod-episodes
R2_IMAGES_PUBLIC_URL=https://your-account-id.r2.cloudflarestorage.com/automapod-images
# Custom domain (optional, if configured)
R2_EPISODES_CUSTOM_DOMAIN=https://audio.automapod.app
R2_IMAGES_CUSTOM_DOMAIN=https://images.automapod.app

# ============================================
# OPTIONAL - Email Service
# ============================================
# RESEND_API_KEY=your-resend-api-key

# ============================================
# OPTIONAL - Stripe (Payments)
# ============================================
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# STRIPE_PRICE_ID=your-stripe-price-id

# ============================================
# Development Settings
# ============================================
NODE_ENV=development
